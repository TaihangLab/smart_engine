# ============================================
# 统一身份认证平台集成配置示例
# ============================================
# 将以下配置添加到你的 .env 文件或 Nacos 配置中心

# ============================================
# 登录配置
# ============================================

# 是否启用外部登录（综管平台）
# true: 允许通过综管平台登录
# false: 禁用外部登录
ENABLE_EXTERNAL_LOGIN=true

# 是否启用本地登录
# true: 允许使用本地账号密码登录
# false: 禁用本地登录，只允许外部登录
ENABLE_LOCAL_LOGIN=true

# 外部登录页面URL
# 当本地登录禁用时，用户会被重定向到此URL
EXTERNAL_LOGIN_URL=https://sso.example.com/login

# ============================================
# 超管配置
# ============================================

# 超管用户名列表（JSON数组格式）
# 这些用户将自动获得 ROLE_ALL 超管角色
# 适用于本地创建的超级管理员
SUPER_ADMIN_USERS=["admin", "superadmin", "system"]

# 超管外部用户ID列表（JSON数组格式）
# 综管平台的这些用户ID将自动获得 ROLE_ALL 超管角色
# 适用于从综管平台同步的超级管理员
# 示例：综管平台的主管理员用户ID
SUPER_ADMIN_EXTERNAL_IDS=["100001", "100002", "ADMIN001"]

# ============================================
# 使用说明
# ============================================

# 1. 超管用户权限
#    - 超管用户拥有所有权限，不受RBAC权限系统限制
#    - 超管用户可以访问所有租户的数据
#    - 超管角色编码为 ROLE_ALL
#
# 2. 登录模式
#    - ENABLE_EXTERNAL_LOGIN=true 且 ENABLE_LOCAL_LOGIN=true:
#      同时支持外部登录和本地登录（推荐用于过渡期）
#
#    - ENABLE_EXTERNAL_LOGIN=true 且 ENABLE_LOCAL_LOGIN=false:
#      只允许外部登录，本地登录请求会被重定向到 EXTERNAL_LOGIN_URL
#
#    - ENABLE_EXTERNAL_LOGIN=false 且 ENABLE_LOCAL_LOGIN=true:
#      只允许本地登录，禁用外部登录
#
# 3. 配置优先级
#    - 优先检查 SUPER_ADMIN_EXTERNAL_IDS（外部用户ID）
#    - 然后检查 SUPER_ADMIN_USERS（本地用户名）
#    - 都不匹配则分配 ROLE_ACCESS 普通角色
#
# 4. 安全建议
#    - 生产环境建议只配置一个主超管账号
#    - 超管用户ID不要轻易泄露
#    - 定期审查超管权限分配情况
#    - 建议在 Nacos 配置中心管理这些配置

# ============================================
# 配置示例场景
# ============================================

# 场景1：完全使用综管平台登录
# ENABLE_EXTERNAL_LOGIN=true
# ENABLE_LOCAL_LOGIN=false
# EXTERNAL_LOGIN_URL=https://sso.company.com/login
# SUPER_ADMIN_EXTERNAL_IDS=["ADMIN001", "SYS_ADMIN"]
# SUPER_ADMIN_USERS=[]

# 场景2：综管平台和本地登录并存（过渡期）
# ENABLE_EXTERNAL_LOGIN=true
# ENABLE_LOCAL_LOGIN=true
# EXTERNAL_LOGIN_URL=https://sso.company.com/login
# SUPER_ADMIN_EXTERNAL_IDS=["ADMIN001"]
# SUPER_ADMIN_USERS=["admin"]

# 场景3：只使用本地登录（不使用综管平台）
# ENABLE_EXTERNAL_LOGIN=false
# ENABLE_LOCAL_LOGIN=true
# EXTERNAL_LOGIN_URL=null
# SUPER_ADMIN_EXTERNAL_IDS=[]
# SUPER_ADMIN_USERS=["admin", "superadmin"]

# ============================================
# 验证配置是否生效
# ============================================

# 1. 检查超管配置
#    使用配置的超管账号登录，查看用户信息中的 roleCode 是否为 "ROLE_ALL"
#
# 2. 检查登录模式
#    尝试本地登录，查看是否正常登录或被重定向
#
# 3. 检查外部用户ID
#    登录后查看数据库 sys_user 表的 external_user_id 字段是否有值
