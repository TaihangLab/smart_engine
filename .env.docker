# ============================================================
# Smart Vision Engine - Docker 环境变量配置
# 复制此文件并根据实际环境修改
# ============================================================

# ==================== 应用基础配置 ====================
REST_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ==================== 数据库配置 ====================
# Docker Compose 内部连接（无需修改）
MYSQL_SERVER=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=smart_vision

# 外部访问端口（宿主机映射）
MYSQL_EXTERNAL_PORT=3306

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 外部访问端口
REDIS_EXTERNAL_PORT=6379

# ==================== RabbitMQ 配置 ====================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

# 外部访问端口
RABBITMQ_EXTERNAL_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ==================== MinIO 配置 ====================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=visionai

# ⚠️ 必须修改：MinIO公共访问地址（服务器的实际IP或域名）
# 后端生成图片/视频URL给前端浏览器用，浏览器需要能访问这个地址
MINIO_PUBLIC_ENDPOINT=172.18.1.1

# 外部访问端口（前端通过此端口访问预警图片/视频）
MINIO_API_PORT=9300
MINIO_CONSOLE_PORT=9301

# ==================== Triton 推理服务器 ====================
# Triton 通常独立部署在GPU服务器上，填写实际地址
TRITON_URL=172.18.1.1:8201
TRITON_TIMEOUT=30
TRITON_UPLOAD_MODE=sftp
TRITON_MODEL_REPOSITORY=/home/user/triton_models

# Triton SSH配置（SFTP上传模式）
TRITON_SSH_HOST=172.18.1.1
TRITON_SSH_PORT=22
TRITON_SSH_USER=user
TRITON_SSH_PASSWORD=User@1234

# ==================== WVP 视频平台 ====================
# WVP 通常独立部署，填写实际地址
WVP_API_URL=http://172.18.1.1:18978
WVP_USERNAME=admin
WVP_PASSWORD=admin

# ==================== LLM 大模型配置 ====================
# 纯文本模型
TEXT_LLM_PROVIDER=ollama
TEXT_LLM_BASE_URL=http://172.18.1.1:11434/v1
TEXT_LLM_API_KEY=ollama
TEXT_LLM_MODEL=qwen3:32b

# 多模态模型
MULTIMODAL_LLM_PROVIDER=vllm
MULTIMODAL_LLM_BASE_URL=http://172.18.1.1:22002/v1
MULTIMODAL_LLM_API_KEY=EMPTY
MULTIMODAL_LLM_MODEL=Qwen3-VL-30B-A3B-Instruct

# ==================== RTSP 推流配置 ====================
RTSP_STREAMING_ENABLED=true
RTSP_STREAMING_BACKEND=ffmpeg
RTSP_STREAMING_BASE_URL=rtsp://172.18.1.1:5540/detection
RTSP_STREAMING_SIGN=a9b7ba70783b617e9998dc4dd82eb3c5
RTSP_STREAMING_DEFAULT_FPS=30.0
RTSP_STREAMING_CODEC=h265

# ==================== 预警配置 ====================
ALERT_MERGE_ENABLED=true
ALERT_MERGE_WINDOW_SECONDS=10.0
ALERT_MERGE_BASE_DELAY_SECONDS=4.0
ALERT_MERGE_MAX_DURATION_SECONDS=30.0
ALERT_MERGE_IMMEDIATE_LEVELS=
ALERT_VIDEO_ENABLED=true
ALERT_VIDEO_CODEC=h265

# ==================== Label Studio 数据标注（可选） ====================
ML_PIPELINE_ENABLED=false
LABEL_STUDIO_USERNAME=admin@admin.com
LABEL_STUDIO_PASSWORD=admin123456
LABEL_STUDIO_SECRET_KEY=smart-engine-ls-secret-2024

# ⚠️ 必须修改：Label Studio 浏览器跳转地址（前端点"打开标注项目"时用）
LABEL_STUDIO_PUBLIC_URL=http://172.18.1.1:8888
# Label Studio 外部访问端口
LABEL_STUDIO_PORT=8888

