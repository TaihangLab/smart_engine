# ==============================================================================
# Smart Vision Engine - 环境配置示例
# ==============================================================================
# 说明：
# 1. 复制此文件为 .env 并根据实际环境修改配置值
# 2. 配置项按功能模块分组，方便查找和维护
# 3. 带有 [开发/生产] 标记的表示建议在该环境下设置特定值

# ------------------------------------------------------------------------------
# 基本配置
# ------------------------------------------------------------------------------
# 调试模式 [开发: True, 生产: False]
DEBUG=True

# 日志级别: DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO

# 服务端口
REST_PORT=8000

# ------------------------------------------------------------------------------
# 数据库配置 (MySQL)
# ------------------------------------------------------------------------------
MYSQL_SERVER=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=smart_vision
MYSQL_PORT=3306

# 数据库连接池配置
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=100
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=True
DB_ECHO=False
DB_AUTOCOMMIT=False
DB_AUTOFLUSH=False

# ------------------------------------------------------------------------------
# RabbitMQ 消息队列配置
# ------------------------------------------------------------------------------
# 是否启用 RabbitMQ [开发: False, 生产: True]
# 禁用后，预警消息将通过 SSE 直接推送给前端
RABBITMQ_ENABLED=False
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_ALERT_EXCHANGE=alert_exchange
RABBITMQ_ALERT_QUEUE=alert_queue
RABBITMQ_ALERT_ROUTING_KEY=alert

# 死信队列配置
RABBITMQ_DEAD_LETTER_TTL=604800000
RABBITMQ_DEAD_LETTER_MAX_LENGTH=10000
RABBITMQ_MESSAGE_TTL=86400000
RABBITMQ_MAX_RETRIES=3

# ------------------------------------------------------------------------------
# Redis 缓存配置
# ------------------------------------------------------------------------------
REDIS_ENABLED=False
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# MinIO 对象存储配置
# ------------------------------------------------------------------------------
MINIO_ENABLED=False
MINIO_ENDPOINT=192.168.0.14
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET=visionai
MINIO_SKILL_IMAGE_PREFIX=skill-images/
MINIO_LLM_SKILL_ICON_PREFIX=skill-icons/
MINIO_ALERT_IMAGE_PREFIX=alert-images/
MINIO_ALERT_VIDEO_PREFIX=alert-videos/

# ------------------------------------------------------------------------------
# WVP 视频平台配置
# ------------------------------------------------------------------------------
WVP_ENABLED=False
WVP_API_URL=http://192.168.0.14:18080
WVP_USERNAME=admin
WVP_PASSWORD=admin

# ------------------------------------------------------------------------------
# Triton AI 推理服务配置
# ------------------------------------------------------------------------------
TRITON_URL=172.18.1.1:8201
TRITON_MODEL_REPOSITORY=/models
TRITON_TIMEOUT=30
TRITON_SYNC_ENABLED=False

# ------------------------------------------------------------------------------
# 服务控制配置
# ------------------------------------------------------------------------------
# 系统核心服务（必须启用）
SYSTEM_CORE_ENABLED=True

# Nacos 服务注册 [开发: False, 生产: True]
NACOS_ENABLED=False
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_AUTH_TOKEN=SecretKey012345678901234567890123456789012345678901234567
NACOS_AUTH_IDENTITY_KEY=nacos
NACOS_AUTH_IDENTITY_VALUE=nacos
NACOS_HEARTBEAT_INTERVAL=5

# MinIO 企业级服务集群
MINIO_ENABLED=False
COMPENSATION_AUTO_START=False

# ------------------------------------------------------------------------------
# 系统核心服务组件
# ------------------------------------------------------------------------------
# Triton 模型同步
TRITON_SYNC_ENABLED=False

# 技能管理器
SKILL_MANAGER_ENABLED=False

# AI 任务执行器
AI_TASK_EXECUTOR_ENABLED=False

# SSE 连接管理器
SSE_MANAGER_ENABLED=False

# LLM 任务执行器
LLM_TASK_EXECUTOR_ENABLED=False

# 预警复判队列
ALERT_REVIEW_QUEUE_ENABLED=False
ALERT_REVIEW_MAX_WORKERS=1
ALERT_REVIEW_PROCESSING_TIMEOUT=300
ALERT_REVIEW_RETRY_MAX_ATTEMPTS=3
ALERT_REVIEW_COMPLETED_TTL=86400

# ------------------------------------------------------------------------------
# 登录配置
# ------------------------------------------------------------------------------
# 是否启用外部登录（SSO场景，如综管平台）
ENABLE_EXTERNAL_LOGIN=True
# 外部登录页面URL
EXTERNAL_LOGIN_PAGE_URL=http://192.168.1.18:8081/cas/login

# 是否启用本地登录（备用）
ENABLE_LOCAL_LOGIN=True

# ------------------------------------------------------------------------------
# 超管配置
# ------------------------------------------------------------------------------
# 超管用户名列表（本地用户）
SUPER_ADMIN_USERS=["superadmin"]
# 超管外部用户ID列表（综管平台等）
SUPER_ADMIN_EXTERNAL_IDS=[]

# ------------------------------------------------------------------------------
# RTSP 推流配置
# ------------------------------------------------------------------------------
RTSP_STREAMING_ENABLED=True
RTSP_STREAMING_BACKEND=pyav
RTSP_STREAMING_BASE_URL=rtsp://192.168.0.14/detection
RTSP_STREAMING_SIGN=a9b7ba70783b617e9998dc4dd82eb3c5
RTSP_STREAMING_DEFAULT_FPS=30.0
RTSP_STREAMING_MAX_FPS=30.0
RTSP_STREAMING_MIN_FPS=5.0

# ------------------------------------------------------------------------------
# 缓存配置
# ------------------------------------------------------------------------------
# 默认缓存时间（秒）- 5分钟
CACHE_DEFAULT_TTL=300
# 权限缓存时间（秒）- 10分钟
CACHE_PERMISSION_TTL=600
# 菜单缓存时间（秒）- 5分钟
CACHE_MENU_TTL=300
# 最大缓存条目数
CACHE_MAX_SIZE=128

# ------------------------------------------------------------------------------
# 预警数据 Mock 配置（开发/测试环境）
# ------------------------------------------------------------------------------
# 是否启用预警数据 Mock 服务
ALERT_MOCK_ENABLED=False
# 每日目标预警数量（用于生成测试数据）
ALERT_MOCK_DAILY_TARGET=50
# 回溯天数（补充最近 N 天的数据）
ALERT_MOCK_LOOKBACK_DAYS=8

# ------------------------------------------------------------------------------
# 预警数据库重构配置
# ------------------------------------------------------------------------------
# 预警表重构模式：auto=自动，manual=手动，disabled=禁用
ALERT_REDESIGN_MODE=auto
# 迁移最近 N 天的数据作为样本
ALERT_REDESIGN_MIGRATE_DAYS=7
# 是否备份原始表为 alerts_legacy
ALERT_REDESIGN_BACKUP_LEGACY=True
# 系统启动时自动初始化重构表结构
ALERT_REDESIGN_AUTO_INIT=True

# ------------------------------------------------------------------------------
# 智能填充助手配置（测试场景专用）
# ------------------------------------------------------------------------------
SMART_FILL_ENABLED=False
SMART_FILL_MOCK_DATA_PATH=config/smart_fill_mock.json

# ------------------------------------------------------------------------------
# 报警补偿服务配置
# ------------------------------------------------------------------------------
ALERT_COMPENSATION_INTERVAL=30
ALERT_MAX_RETRY_HOURS=24
ALERT_MAX_COMPENSATION_COUNT=20
